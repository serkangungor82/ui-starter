# JWT
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# DB — varsayılan SQLite. Postgres örnek:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/uistarter
DATABASE_URL=sqlite:///./app.db

# CORS — virgülle ayrılmış izin verilen origin'ler
CORS_ORIGINS=http://localhost:3000

# Microsoft OAuth (kurumsal hesap girişi) — opsiyonel
# Boş ise Microsoft butonu "henüz konfigüre edilmedi" hatası döner.
# Azure App Registration adımları:
#   1) https://portal.azure.com → Azure Active Directory → App registrations → New
#   2) Supported account types: "Accounts in any organizational directory (multitenant)"
#      (kişisel Microsoft hesaplarını dışarda bırakır)
#   3) Redirect URI (Web): http://api.localhost:8000/auth/microsoft/callback (dev)
#   4) Certificates & secrets → New client secret → değeri MS_CLIENT_SECRET'a yapıştır
#   5) Application (client) ID'yi MS_CLIENT_ID'a yapıştır
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_REDIRECT_URI=http://api.localhost:8000/auth/microsoft/callback
